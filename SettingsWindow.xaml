                    <!-- ===== Page 2: 功能 ===== -->
                    <TabItem>
                        <Grid Margin="28,20,61,20">
                            <ListBox x:Name="MonitorList"
                                     Background="Transparent" BorderThickness="0"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="MonitorList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            CornerRadius="10" Padding="14"
                                                            Cursor="Hand"
                                                            Background="{DynamicResource ThemeCardBg}"
                                                            BorderBrush="{DynamicResource ThemeBorder}"
                                                            BorderThickness="1"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="10" Opacity="0.05"
                                                                              ShadowDepth="1" Direction="270"
                                                                              Color="#1D1D2E"/>
                                                        </Border.Effect>
                                                        <Border.RenderTransform>
                                                            <ScaleTransform x:Name="RowScale" ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="Background"
                                                                    Value="{DynamicResource ThemeHover}"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RowScale"
                                                                                                       Storyboard.TargetProperty="ScaleX">
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="1.02">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <PowerEase EasingMode="EaseOut" Power="2"/>
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.01">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <PowerEase EasingMode="EaseOut" Power="2"/>
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="RowScale"
                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                         To="1" Duration="0:0:0.18">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <PowerEase EasingMode="EaseOut" Power="2"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="{DynamicResource ThemeAccentBg}"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush"
                                                                    Value="{DynamicResource ThemeAccent}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="40" Height="40"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ThemeIconTile}"
                                                    HorizontalAlignment="Left">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="6" Opacity="0.06"
                                                                      ShadowDepth="1" Direction="270"
                                                                      Color="#1D1D2E"/>
                                                </Border.Effect>
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="18"
                                                           Foreground="#4685C0"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeFg}"
                                                           FontFamily="{StaticResource FontUI}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource ThemeFgTertiary}"
                                                           FontFamily="{StaticResource FontUI}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <ToggleButton Grid.Column="2"
                                                          Width="44" Height="24"
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled}"
                                                          Checked="MonitorToggle_Changed"
                                                          Unchecked="MonitorToggle_Changed"
                                                          Tag="{Binding Id}"
                                                          VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <!-- ===== Page 3: 插件 ===== -->
                    <TabItem>
                        <Grid Margin="28,20,61,20">
                            <ListBox x:Name="PluginList"
                                     Background="Transparent" BorderThickness="0"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="PluginList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            CornerRadius="10" Padding="14"
                                                            Cursor="Hand"
                                                            Background="{DynamicResource ThemeCardBg}"
                                                            BorderBrush="{DynamicResource ThemeBorder}"
                                                            BorderThickness="1"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="10" Opacity="0.05"
                                                                              ShadowDepth="1" Direction="270"
                                                                              Color="#1D1D2E"/>
                                                        </Border.Effect>
                                                        <Border.RenderTransform>
                                                            <ScaleTransform x:Name="RowScale" ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="Background"
                                                                    Value="{DynamicResource ThemeHover}"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RowScale"
                                                                                                       Storyboard.TargetProperty="ScaleX">
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="1.02">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <PowerEase EasingMode="EaseOut" Power="2"/>
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.01">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <PowerEase EasingMode="EaseOut" Power="2"/>
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="RowScale"
                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                         To="1" Duration="0:0:0.18">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <PowerEase EasingMode="EaseOut" Power="2"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="{DynamicResource ThemeAccentBg}"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush"
                                                                    Value="{DynamicResource ThemeAccent}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="40" Height="40"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ThemeIconTile}"
                                                    HorizontalAlignment="Left">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="6" Opacity="0.06"
                                                                      ShadowDepth="1" Direction="270"
                                                                      Color="#1D1D2E"/>
                                                </Border.Effect>
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="18"
                                                           Foreground="#4685C0"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeFg}"
                                                           FontFamily="{StaticResource FontUI}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource ThemeFgTertiary}"
                                                           FontFamily="{StaticResource FontUI}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="&#xE76C;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="#C7C7CC"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <!-- ===== Page 4: 更多 ===== -->
                    <TabItem>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      Padding="28,20,56,20">
                            <StackPanel>
                                <TextBlock Text="常规" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,12" Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="开机自启动" FontSize="13"
                                                   Foreground="{DynamicResource ThemeFg}"
                                                   FontFamily="{StaticResource FontUI}"/>
                                        <TextBlock Text="登录 Windows 时自动运行" FontSize="11"
                                                   Foreground="{DynamicResource ThemeFgTertiary}"
                                                   FontFamily="{StaticResource FontUI}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="StartupToggle"
                                                  Grid.Column="1" Width="44" Height="24"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Checked="StartupToggle_Changed"
                                                  Unchecked="StartupToggle_Changed"/>
                                </Grid>

                                <Grid Margin="0,0,0,12" Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="隐藏托盘图标" FontSize="13"
                                                   Foreground="{DynamicResource ThemeFg}"
                                                   FontFamily="{StaticResource FontUI}"/>
                                        <TextBlock Text="Ctrl+Alt+Click 灵动岛重新打开设置"
                                                   FontSize="11" Foreground="{DynamicResource ThemeFgTertiary}"
                                                   FontFamily="{StaticResource FontUI}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="HideTrayToggle"
                                                  Grid.Column="1" Width="44" Height="24"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Checked="HideTrayToggle_Changed"
                                                  Unchecked="HideTrayToggle_Changed"/>
                                </Grid>

                                <Grid Margin="0,0,0,12" Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="按住隐藏" FontSize="13"
                                                   Foreground="{DynamicResource ThemeFg}"
                                                   FontFamily="{StaticResource FontUI}"/>
                                        <TextBlock Text="按住指定按键时临时隐藏灵动岛"
                                                   FontSize="11" Foreground="{DynamicResource ThemeFgTertiary}"
                                                   FontFamily="{StaticResource FontUI}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ComboBox x:Name="HoldToHideKeyCombo"
                                              Grid.Column="1"
                                              Margin="12,0,0,0"
                                              SelectionChanged="HoldToHideKeyCombo_Changed"/>
                                </Grid>

                                <Border Style="{StaticResource Separator}"/>
                                <TextBlock Text="关于" Style="{StaticResource SectionHeader}"/>

                                <!-- 版本卡片：版本号 + GitHub 链接 + 检查更新 -->
                                <Border CornerRadius="12" Padding="16,14" Margin="0,0,0,12"
                                        Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorder}">
                                    <Border.BorderThickness>1</Border.BorderThickness>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" Opacity="0.08"
                                                          ShadowDepth="2" Direction="270"
                                                          Color="#2A2A3E"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- 版本号行 -->
                                        <Grid Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="FluidBar" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeFg}"
                                                           FontFamily="{StaticResource FontUI}"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="{DynamicResource ThemeAccentBg}" CornerRadius="8" Padding="8,2" Margin="8,0,0,0">
                                                    <TextBlock x:Name="VersionTag" Text="v2.0.0" FontSize="11"
                                                               Foreground="{DynamicResource ThemeAccent}"
                                                               FontFamily="{StaticResource FontUI}"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="UpdateStatusText" Text="已是最新版本"
                                                       FontSize="10" Foreground="{DynamicResource ThemeFgTertiary}"
                                                       FontFamily="{StaticResource FontUI}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>

                                        <Border Style="{StaticResource Separator}" Margin="0,0,0,12"/>

                                        <!-- GitHub 仓库链接 -->
                                        <Button x:Name="GitHubLinkBtn" Click="GitHubLink_Click"
                                                Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,12">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="GhBg" Background="{DynamicResource ThemeHover}"
                                                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                                            CornerRadius="8" Padding="10,6"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform x:Name="GhScale" ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="13" Foreground="{DynamicResource ThemeFg}"
                                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="github.com/Doulor/FluidBar" FontSize="11"
                                                                       Foreground="{DynamicResource ThemeFg}"
                                                                       FontFamily="{StaticResource FontUI}"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10" Foreground="{DynamicResource ThemeFgTertiary}"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="GhBg" Property="Background" Value="{DynamicResource ThemeSurface}"/>
                                                            <Setter TargetName="GhBg" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 检查更新按钮 -->
                                        <Button x:Name="CheckUpdateBtn" Click="CheckUpdate_Click"
                                                Content="检查更新" Height="32" Padding="16,0"
                                                FontSize="12"
                                                FontFamily="{StaticResource FontUI}"
                                                Foreground="#FFFFFF"
                                                Cursor="Hand"
                                                HorizontalAlignment="Left">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="UpBg" CornerRadius="8" Padding="16,0"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#4685C0" Offset="0"/>
                                                                <GradientStop Color="#5A9BD8" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.RenderTransform>
                                                            <ScaleTransform x:Name="UpScale" ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="10" Opacity="0.20"
                                                                              ShadowDepth="2" Direction="270"
                                                                              Color="#2A4A6E"/>
                                                        </Border.Effect>
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="UpBg" Property="Opacity" Value="0.92"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="UpBg" Property="Opacity" Value="0.82"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 自动检查更新开关 -->
                                        <Grid Margin="0,12,0,0">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="启动时自动检查更新" FontSize="12"
                                                           Foreground="{DynamicResource ThemeFg}"
                                                           FontFamily="{StaticResource FontUI}"/>
                                                <TextBlock Text="检测到新版本时以灵动岛提示一次"
                                                           FontSize="10" Foreground="{DynamicResource ThemeFgTertiary}"
                                                           FontFamily="{StaticResource FontUI}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="AutoUpdateToggle"
                                                          Grid.Column="1" Width="44" Height="24"
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          Checked="AutoUpdateToggle_Changed"
                                                          Unchecked="AutoUpdateToggle_Changed"
                                                          HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Separator}"/>

                                <Button x:Name="ResetBtn"
                                        Content="重置所有设置"
                                        Height="34" Padding="16,0"
                                        FontSize="12"
                                        FontFamily="{StaticResource FontUI}"
                                        Foreground="#FF3B30"
                                        Background="Transparent"
                                        BorderBrush="#FFD1CE"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        HorizontalAlignment="Left"
                                        Click="ResetBtn_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg"
                                                    Background="Transparent"
                                                    BorderBrush="#FFD1CE"
                                                    BorderThickness="1"
                                                    CornerRadius="8" Padding="16,0"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Border.RenderTransform>
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg"
                                                            Property="Background"
                                                            Value="#FFF0EF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bg"
                                                            Property="Background"
                                                            Value="#FFE0DE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- 插件详情页 -->
                <Grid x:Name="PluginDetailPanel" Visibility="Collapsed"
                      Opacity="0"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="DetailPanelTranslate" X="28"/>
                    </Grid.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False"
                                  Padding="28,20,28,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="52" Height="52"
                                        CornerRadius="14" Background="{DynamicResource ThemeIconTile}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" Opacity="0.08"
                                                          ShadowDepth="2" Direction="270"
                                                          Color="#1D1D2E"/>
                                    </Border.Effect>
                                    <TextBlock x:Name="DetailIcon"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="24" Foreground="#4685C0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="14,0,0,0">
                                    <TextBlock x:Name="DetailName" FontSize="17"
                                               FontWeight="SemiBold" Foreground="{DynamicResource ThemeFg}"
                                               FontFamily="{StaticResource FontUI}"/>
                                    <TextBlock x:Name="DetailDesc" FontSize="12"
                                               Foreground="{DynamicResource ThemeFgTertiary}"
                                               FontFamily="{StaticResource FontUI}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14" Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="DetailEnabledLabel"
                                           Grid.Column="0" Text="启用项目" FontSize="13"
                                           Foreground="{DynamicResource ThemeFg}"
                                           FontFamily="{StaticResource FontUI}"
                                           VerticalAlignment="Center"/>
                                <ToggleButton x:Name="DetailEnabledToggle"
                                              Grid.Column="1" Width="44" Height="24"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              Checked="DetailEnabled_Changed"
                                              Unchecked="DetailEnabled_Changed"/>
                            </Grid>

                            <Border Style="{StaticResource Separator}"/>
                            <TextBlock x:Name="DetailSettingsHeader"
                                       Text="项目设置"
                                       Style="{StaticResource SectionHeader}"/>
                            <StackPanel x:Name="PluginSettingsContainer"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
