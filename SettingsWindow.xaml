<Window x:Class="FluidBar.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluidBar"
        Width="960" Height="780"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <!-- =============== SLIDER =============== -->
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5"
                                                        Background="#FF4F6AFF"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5"
                                                        Background="#FF2A2D35"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14" Fill="#FFFFFFFF">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="3" Opacity="0.2"
                                                                          ShadowDepth="1" Color="#FF000000"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============== SCROLLBAR =============== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="1.5" Background="#FF3A3D47" MinHeight="16"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============== TOGGLE =============== -->
        <Style x:Key="Toggle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="40" Height="22">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FF2A2D35" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbX"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FF4F6AFF" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbX"
                                                             Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border CornerRadius="11" Width="40" Height="22">
                                <Border.Background>
                                    <SolidColorBrush x:Name="TrackBrush" Color="#FF2A2D35"/>
                                </Border.Background>
                            </Border>
                            <Border x:Name="Thumb" CornerRadius="8" Width="18" Height="18"
                                    HorizontalAlignment="Left" Margin="2,0,0,0"
                                    Background="#FFFFFFFF">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbX" X="0"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="2" Opacity="0.15"
                                                      ShadowDepth="1" Color="#FF000000"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============== COMBOBOX =============== -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Background" Value="#FF1A1D24"/>
            <Setter Property="Foreground" Value="#FFB0B8C8"/>
            <Setter Property="BorderBrush" Value="#FF2A2D35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"/>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                            <ContentPresenter IsHitTestVisible="False" VerticalAlignment="Center"
                                              Margin="8,0,22,0"
                                              Content="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Path Data="M0,0 L3,3 L6,0" Stroke="#FF5A6070" StrokeThickness="1.5"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Margin="0,0,8,0" Stretch="Uniform" Width="6" Height="4"
                                  IsHitTestVisible="False"/>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                <Border Background="#FF1E2128" BorderBrush="#FF2A2D35"
                                        BorderThickness="1" CornerRadius="6"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="160"
                                        Margin="0,3,0,0">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="#FFB0B8C8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============== POSITION RADIO =============== -->
        <Style x:Key="PosRadio" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#184F6AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============== NAV BUTTON =============== -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" CornerRadius="10" Padding="14,12"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#144F6AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- =============== MAIN =============== -->
    <Border x:Name="MainBorder" CornerRadius="12"
            Background="#F212141A"
            BorderBrush="#1EFFFFFF" BorderThickness="1"
            SizeChanged="MainBorder_SizeChanged">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.4" ShadowDepth="0" Color="#FF000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== SIDEBAR ========== -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12"
                    Background="#0AFFFFFF" BorderBrush="#0CFFFFFF"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sidebar header -->
                    <StackPanel Grid.Row="0" Margin="18,18,18,0">
                        <TextBlock Text="FluidBar" FontSize="18" FontWeight="Bold"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   Foreground="#FFECF0F5"/>
                        <TextBlock Text="v2.0" FontSize="12"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   Foreground="#FF5A6070" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Nav items -->
                    <StackPanel Grid.Row="1" Margin="8,14,8,0">
                        <RadioButton x:Name="NavIsland" Style="{StaticResource NavBtn}"
                                     IsChecked="True" Checked="Nav_Changed" Tag="Island">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#FF8A90A0"
                                           VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="灵动岛" FontSize="14"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           Foreground="#FFB0B8C8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavFeatures" Style="{StaticResource NavBtn}"
                                     Checked="Nav_Changed" Tag="Features">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#FF8A90A0"
                                           VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="功能" FontSize="14"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           Foreground="#FFB0B8C8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavPlugins" Style="{StaticResource NavBtn}"
                                     Checked="Nav_Changed" Tag="Plugins">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#FF8A90A0"
                                           VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="插件" FontSize="14"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           Foreground="#FFB0B8C8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavMore" Style="{StaticResource NavBtn}"
                                     Checked="Nav_Changed" Tag="More">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#FF8A90A0"
                                           VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="更多" FontSize="14"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           Foreground="#FFB0B8C8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== CONTENT AREA ========== -->
            <Grid Grid.Column="1" x:Name="ContentArea">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar with back/close -->
                <Grid Grid.Row="0" Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Back button (hidden by default, shown in detail view) -->
                    <Border x:Name="BackBtn" Grid.Column="0"
                            Margin="12,6,0,0" Width="28" Height="28" CornerRadius="7"
                            Background="#184F6AFF" Cursor="Hand"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Visibility="Collapsed" MouseLeftButtonDown="BackBtn_Click">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" Foreground="#FF8A90A0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Close button (top-right) -->
                    <Button x:Name="CloseBtn" Grid.Column="2"
                            Content="&#xE8BB;" Width="32" Height="32"
                            FontFamily="Segoe MDL2 Assets" FontSize="11"
                            Foreground="#FF5A6070" Background="Transparent"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,4,8,0" Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7"
                                        Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#12FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Content panels -->
                <Grid Grid.Row="1" x:Name="ContentRoot" Margin="0">

                    <!-- PAGE: 灵动岛 -->
                    <ScrollViewer x:Name="PageIsland"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,10,14,10">
                        <StackPanel x:Name="PageIslandContent">
                            <!-- populated in code -->
                        </StackPanel>
                    </ScrollViewer>

                    <!-- PAGE: 功能 -->
                    <ListBox x:Name="PageFeatures"
                             Visibility="Collapsed"
                             Background="Transparent" BorderThickness="0"
                             Margin="10,6"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="MonitorList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" CornerRadius="8" Padding="10"
                                                    Cursor="Hand" Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#104F6AFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="#FF4F6AFF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#FFECF0F5" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="#FF5A6070" FontFamily="Segoe UI, Microsoft YaHei UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="2" Width="40" Height="22"
                                                  Style="{StaticResource Toggle}"
                                                  IsChecked="{Binding Enabled}"
                                                  Checked="MonitorToggle_Changed"
                                                  Unchecked="MonitorToggle_Changed"
                                                  Tag="{Binding Id}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- PAGE: 插件 -->
                    <ListBox x:Name="PagePlugins"
                             Visibility="Collapsed"
                             Background="Transparent" BorderThickness="0"
                             Margin="10,6"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="PluginList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" CornerRadius="8" Padding="10"
                                                    Cursor="Hand" Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#104F6AFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="#FF4F6AFF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#FFECF0F5" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="#FF5A6070" FontFamily="Segoe UI, Microsoft YaHei UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="&#xE76C;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="#FF5A6070" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- PAGE: 更多 -->
                    <ScrollViewer x:Name="PageMore"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,10,14,10">
                        <StackPanel x:Name="PageMoreContent">
                            <!-- populated in code -->
                        </StackPanel>
                    </ScrollViewer>

                    <!-- DETAIL PANEL (for plugin/monitor detail) -->
                    <ScrollViewer x:Name="PageDetail"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,10,14,10">
                        <StackPanel>
                            <!-- Plugin header -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28"
                                        CornerRadius="7" Background="#FF1A1D24">
                                    <TextBlock x:Name="DetailIcon"
                                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="#FF4F6AFF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock x:Name="DetailName" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#FFECF0F5" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                    <TextBlock x:Name="DetailDesc" FontSize="10"
                                               Foreground="#FF5A6070" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                </StackPanel>
                            </Grid>

                            <!-- Enable toggle -->
                            <Border Background="#0AFFFFFF" CornerRadius="8"
                                    BorderBrush="#0CFFFFFF" BorderThickness="1"
                                    Padding="10,8" Margin="0,0,0,8">
                                <Grid Height="26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailEnabledLabel"
                                               Grid.Column="0" Text="启用" FontSize="11"
                                               Foreground="#FFB0B8C8" FontFamily="Segoe UI, Microsoft YaHei UI"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton x:Name="DetailEnabledToggle"
                                                  Grid.Column="1" Width="40" Height="22"
                                                  Style="{StaticResource Toggle}"
                                                  Checked="DetailEnabled_Changed"
                                                  Unchecked="DetailEnabled_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Separator -->
                            <Border Height="1" Background="#08FFFFFF" Margin="0,4,0,8"/>

                            <TextBlock x:Name="DetailSettingsHeader" Text="设置"
                                       FontSize="11" FontWeight="SemiBold" Foreground="#FF8A90A0"
                                       FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,8"/>
                            <StackPanel x:Name="PluginSettingsContainer"/>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
