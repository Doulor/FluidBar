                                            <StackPanel>
                                                <Border x:Name="PrevT" Width="54" Height="28"
                                                        CornerRadius="8" Background="{DynamicResource ThemeHover}"
                                                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                                                <TextBlock Text="顶部" FontSize="10"
                                                           Foreground="{DynamicResource ThemeFgTertiary}"
