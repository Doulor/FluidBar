                                        </RadioButton>

                                        <RadioButton x:Name="PosBottomRight" Tag="BottomRight"
                                                     Grid.Row="1" Grid.Column="2"
                                                     Margin="2"
                                                     Style="{StaticResource PosRadioStyle}"
                                                     Checked="PositionRadio_Changed">
                                            <StackPanel>
                                                <Border x:Name="PrevBR" Width="54" Height="28"
                                                        CornerRadius="8" Background="{DynamicResource ThemeHover}"
                                                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                                                <TextBlock Text="右下" FontSize="10"
                                                           Foreground="{DynamicResource ThemeFgTertiary}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </Grid>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
