                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="&#xEA86;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="20" Foreground="#4685C0" Margin="0,0,0,8"/>
                                                <TextBlock Text="插件系统" FontFamily="{StaticResource FontDisplay}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeFg}" Margin="0,0,0,4"/>
